# SkySuite Mission Control — environment config
# Copy to .env and fill in real values. Do NOT commit .env.

# Local Postgres (Phase 1)
DATABASE_URL=postgresql://skysuite:skysuite_local_dev@localhost:5432/skysuite

# Notion internal integration token (used by backfill + Phase 2 sync)
NOTION_TOKEN=secret_xxxxx

# Anthropic API key — used to auto-match meetings to companies when title/email
# heuristics fail. Without this, AI fallback is skipped (cheap heuristics still run).
ANTHROPIC_API_KEY=sk-ant-xxxxx

# HTTP Basic Auth (production). If either is empty, auth is disabled —
# fine for localhost, REQUIRED on any public deployment.
BASIC_AUTH_USER=matt
BASIC_AUTH_PASS=replace-with-strong-password

# When you move to Supabase (Phase 3), swap to:
# DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OpenClaw gateway (Phase 1 chat interface). Without these, the agent-card
# 💬 Chat buttons will return 503. Get the token from Railway env var
# OPENCLAW_GATEWAY_TOKEN on the clawdbot-railway-template service.
OPENCLAW_WS_URL=wss://clawdbot-railway-template-production-b8f4.up.railway.app/
OPENCLAW_TOKEN=
